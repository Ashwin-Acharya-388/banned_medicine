# ============================================================
# Indian Banned Medicines Data Pipeline — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ============================================================

# --- Database ------------------------------------------------
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/banned_drugs

# Connection pool tuning (optional)
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_TIMEOUT=30

# --- Directories ---------------------------------------------
# Where downloaded PDFs are stored
DOWNLOAD_DIR=./downloads

# Where log files are written
LOG_DIR=./logs

# --- Scraper behaviour ----------------------------------------
# Random delay (seconds) between HTTP requests
SCRAPE_DELAY_MIN=2
SCRAPE_DELAY_MAX=5

# Maximum retry attempts for failed downloads
MAX_RETRIES=3

# HTTP request timeout (seconds)
REQUEST_TIMEOUT=30

# --- Target URLs (override if mirrors change) -----------------
# CDSCO_NOTIFICATIONS_URL=https://cdsco.gov.in/opencms/opencms/en/Notifications/
# CDSCO_BASE_URL=https://cdsco.gov.in
# PIB_BASE_URL=https://pib.gov.in
# PIB_SEARCH_URL=https://pib.gov.in/allRel.aspx
